generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), postgis, pgcrypto]
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  passenger
  driver
  admin
}

enum ComfortClass {
  economy
  standard
  comfort
}

enum InsuranceCategory {
  third_party
  comprehensive
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum VehicleReviewStatus {
  pending
  approved
  rejected
  deleted
}

enum TripStatus {
  scheduled
  boarding
  in_transit
  completed
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  authenticated
  completed
  cancelled
  no_show
}

enum PaymentStatus {
  initiated
  escrow_held
  released
  refunded
  failed
}

enum PaymentMethod {
  airtel_money
  tnm_mpamba
  visa
  mastercard
  bank_transfer
}

enum BookingPaymentStatus {
  unpaid
  held_in_escrow
  released
  refunded
}

enum WalletTxType {
  credit
  withdrawal
}

enum WalletWithdrawalStatus {
  queued
  processing
  completed
  failed
}

enum OtpPurpose {
  account_verification
  withdrawal
  password_reset
}

enum OtpStatus {
  active
  used
  expired
}

enum WalletTxKind {
  trip_payout_credit
  refund_convenience_credit
  withdrawal_debit
  admin_adjustment_credit
  admin_adjustment_debit
}

enum RefundStatus {
  requested
  processing
  completed
  failed
  rejected
}

enum CodeAuditResult {
  success
  mismatch
  expired
  already_used
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone                 String    @unique @db.VarChar(20)
  email                 String?   @unique @db.VarChar(255)
  fullName              String    @map("full_name") @db.VarChar(255)
  passwordHash          String    @map("password_hash")
  role                  UserRole  @default(passenger)
  profilePhotoUrl       String?   @map("profile_photo_url")
  idVerified            Boolean   @default(false) @map("id_verified")
  isVerified            Boolean   @default(false) @map("is_verified")
  rating                Decimal?  @db.Decimal(3, 2)
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(20)
  fcmToken              String?   @map("fcm_token")
  isActive              Boolean   @default(true) @map("is_active")
  refreshToken          String?   @map("refresh_token")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz()
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  driverProfile DriverProfile?
  bookings      Booking[]
  payments      Payment[]
  pendingPayments PendingPayment[]
  refunds       PaymentRefund[]
  reviews       Review[]
  otpCodes      OtpCode[]

  @@map("users")
}

model DriverProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  licenseNumber    String   @unique @map("license_number") @db.VarChar(50)
  licenseExpiry    DateTime @map("license_expiry") @db.Date
  licenseDocUrl    String?  @map("license_doc_url")
  profilePhotoUrl  String?  @map("profile_photo_url")
  idFrontUrl       String?  @map("id_front_url")
  idBackUrl        String?  @map("id_back_url")
  isApproved       Boolean      @default(false) @map("is_approved")
  reviewStatus     ReviewStatus @default(rejected) @map("review_status")
  reviewRequestedAt DateTime?   @map("review_requested_at") @db.Timestamptz()
  totalTrips       Int      @default(0) @map("total_trips")
  totalEarningsMwk BigInt   @default(0) @map("total_earnings_mwk")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]
  trips        Trip[]
  payments     Payment[]
  pendingPayments PendingPayment[]
  refunds      PaymentRefund[]
  wallet       DriverWallet?
  transactions WalletTransaction[]
  auditLogs    SecretCodeAuditLog[]
  reviews      Review[]
  withdrawalRequests WalletWithdrawalRequest[]

  @@map("driver_profiles")
}

model Vehicle {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId      String       @map("driver_id") @db.Uuid
  make          String       @db.VarChar(100)
  model         String       @db.VarChar(100)
  year          Int          @db.SmallInt
  plateNumber   String       @unique @map("plate_number") @db.VarChar(20)
  cofNumber     String?      @map("cof_number") @db.VarChar(80)
  cofExpiry     DateTime?    @map("cof_expiry") @db.Date
  insuranceCategory InsuranceCategory? @map("insurance_category")
  insuranceExpiry DateTime?  @map("insurance_expiry") @db.Date
  insuranceDocUrl String?    @map("insurance_doc_url")
  comfortClass  ComfortClass @default(economy) @map("comfort_class")
  seatCapacity  Int          @map("seat_capacity") @db.SmallInt
  color         String?      @db.VarChar(50)
  reviewStatus  VehicleReviewStatus @default(approved) @map("review_status")
  photoUrl      String?      @map("photo_url")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trips  Trip[]
  images VehicleImage[]

  @@map("vehicles")
}

model VehicleImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId String   @map("vehicle_id") @db.Uuid
  url       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_images")
}

model MalawiLocation {
  id                   Int      @id
  region               String   @db.VarChar(100)
  district             String   @db.VarChar(100)
  traditionalAuthority String?  @map("traditional_authority") @db.VarChar(150)
  village              String?  @db.VarChar(150)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  country              String   @default("Malawi") @db.VarChar(100)

  @@index([district])
  @@map("malawi_locations")
}

model Trip {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId            String       @map("driver_id") @db.Uuid
  vehicleId           String       @map("vehicle_id") @db.Uuid
  originName          String       @map("origin_name") @db.VarChar(255)
  pickupPoint         String?      @map("pickup_point") @db.VarChar(255)
  originPoint         Unsupported("geometry(Point, 4326)")? @map("origin_point")
  destinationName     String       @map("destination_name") @db.VarChar(255)
  destinationPoint    Unsupported("geometry(Point, 4326)")? @map("destination_point")
  routePolyline       String?      @map("route_polyline")
  departureTime       DateTime     @map("departure_time") @db.Timestamptz()
  availableSeats      Int          @map("available_seats") @db.SmallInt
  totalSeats          Int          @map("total_seats") @db.SmallInt
  comfortClass        ComfortClass @map("comfort_class")
  status              TripStatus   @default(scheduled)
  distanceKm          Decimal?     @map("distance_km") @db.Decimal(8, 2)
  baseFareMwk         BigInt?      @map("base_fare_mwk")
  estimatedDurationMinutes Int?    @map("estimated_duration_minutes")
  gpsTrackingActive   Boolean      @default(false) @map("gps_tracking_active")
  currentLocation     Unsupported("geometry(Point, 4326)")? @map("current_location")
  startedAt           DateTime?    @map("started_at") @db.Timestamptz()
  completedAt         DateTime?    @map("completed_at") @db.Timestamptz()
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  driver   DriverProfile @relation(fields: [driverId], references: [id])
  vehicle  Vehicle       @relation(fields: [vehicleId], references: [id])
  bookings Booking[]
  pendingPayments PendingPayment[]

  @@map("trips")
}

model Booking {
  id                        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId                    String               @map("trip_id") @db.Uuid
  passengerId               String               @map("passenger_id") @db.Uuid
  seatsBooked               Int                  @default(1) @map("seats_booked") @db.SmallInt
  boardingPoint             String               @map("boarding_point") @db.VarChar(255)
  boardingPointGeo          Unsupported("geometry(Point, 4326)")? @map("boarding_point_geo")
  dropOffPoint              String?              @map("drop_off_point") @db.VarChar(255)
  secretCode                String               @map("secret_code") @db.Char(60)
  rawSecretCode             String?              @map("raw_secret_code") @db.VarChar(10)
  codeExpiresAt             DateTime?            @map("code_expires_at") @db.Timestamptz()
  codeUsed                  Boolean              @default(false) @map("code_used")
  authAttemptCount          Int                  @default(0) @map("auth_attempt_count") @db.SmallInt
  status                    BookingStatus        @default(pending)
  fareMwk                   BigInt               @map("fare_mwk")
  paymentStatus             BookingPaymentStatus @default(unpaid) @map("payment_status")
  emergencyContactNotified  Boolean              @default(false) @map("emergency_contact_notified")
  ratedDriver               Boolean              @default(false) @map("rated_driver")
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  trip      Trip                 @relation(fields: [tripId], references: [id])
  passenger User                 @relation(fields: [passengerId], references: [id])
  payment   Payment?
  pendingPayment PendingPayment?
  refunds   PaymentRefund[]
  auditLogs SecretCodeAuditLog[]
  review    Review?
  walletTx  WalletTransaction[]

  @@map("bookings")
}

model SecretCodeAuditLog {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId    String          @map("booking_id") @db.Uuid
  driverId     String?         @map("driver_id") @db.Uuid
  enteredCode  String          @map("entered_code") @db.VarChar(10)
  result       CodeAuditResult
  ipAddress    String?         @map("ip_address")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  booking Booking        @relation(fields: [bookingId], references: [id])
  driver  DriverProfile? @relation(fields: [driverId], references: [id])

  @@map("secret_code_audit_log")
}

model Payment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String        @unique @map("booking_id") @db.Uuid
  passengerId     String        @map("passenger_id") @db.Uuid
  driverId        String        @map("driver_id") @db.Uuid
  grossAmountMwk  BigInt        @map("gross_amount_mwk")
  fareAmountMwk   BigInt        @map("fare_amount_mwk")
  providerFeeMwk  BigInt        @default(0) @map("provider_fee_mwk")
  providerFeeRate Decimal       @default(0) @map("provider_fee_rate") @db.Decimal(8, 4)
  systemFeeMwk    BigInt        @map("system_fee_mwk")
  systemFeeRate   Decimal       @map("system_fee_rate") @db.Decimal(8, 4)
  customerAmountMwk BigInt      @map("customer_amount_mwk")
  commissionMwk   BigInt        @map("commission_mwk")
  commissionRate  Decimal       @map("commission_rate") @db.Decimal(4, 2)
  netAmountMwk    BigInt        @map("net_amount_mwk")
  paymentMethod   PaymentMethod @map("payment_method")
  gatewayRef      String?       @map("gateway_ref") @db.VarChar(255)
  provider        String        @default("paychangu") @db.VarChar(50)
  providerReference String?     @map("provider_reference") @db.VarChar(255)
  providerPayload Json?         @map("provider_payload")
  status          PaymentStatus @default(initiated)
  verifiedAt      DateTime?     @map("verified_at") @db.Timestamptz()
  escrowHeldAt    DateTime?     @map("escrow_held_at") @db.Timestamptz()
  releasedAt      DateTime?     @map("released_at") @db.Timestamptz()
  refundedAt      DateTime?     @map("refunded_at") @db.Timestamptz()
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  booking   Booking       @relation(fields: [bookingId], references: [id])
  passenger User          @relation(fields: [passengerId], references: [id])
  driver    DriverProfile @relation(fields: [driverId], references: [id])
  refunds   PaymentRefund[]
  walletTx  WalletTransaction[]

  @@map("payments")
}

model PaymentRefund {
  id                         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId                  String       @map("payment_id") @db.Uuid
  bookingId                  String       @map("booking_id") @db.Uuid
  passengerId                String       @map("passenger_id") @db.Uuid
  driverId                   String       @map("driver_id") @db.Uuid
  status                     RefundStatus @default(requested)
  reason                     String?
  originalCustomerAmountMwk  BigInt       @map("original_customer_amount_mwk")
  refundableBaseMwk          BigInt       @map("refundable_base_mwk")
  convenienceFeeRate         Decimal      @map("convenience_fee_rate") @db.Decimal(8, 4)
  convenienceFeeMwk          BigInt       @map("convenience_fee_mwk")
  driverConvenienceShareRate Decimal      @map("driver_convenience_share_rate") @db.Decimal(8, 4)
  driverConvenienceShareMwk  BigInt       @map("driver_convenience_share_mwk")
  platformConvenienceFeeMwk  BigInt       @map("platform_convenience_fee_mwk")
  refundAmountMwk            BigInt       @map("refund_amount_mwk")
  provider                   String       @default("paychangu") @db.VarChar(50)
  providerReference          String?      @map("provider_reference") @db.VarChar(255)
  providerPayload            Json?        @map("provider_payload")
  requestedAt                DateTime     @default(now()) @map("requested_at") @db.Timestamptz()
  processedAt                DateTime?    @map("processed_at") @db.Timestamptz()
  failedAt                   DateTime?    @map("failed_at") @db.Timestamptz()
  failureReason              String?      @map("failure_reason")

  payment   Payment       @relation(fields: [paymentId], references: [id])
  booking   Booking       @relation(fields: [bookingId], references: [id])
  passenger User          @relation(fields: [passengerId], references: [id])
  driver    DriverProfile @relation(fields: [driverId], references: [id])
  walletTx  WalletTransaction[]

  @@index([bookingId])
  @@index([passengerId])
  @@index([driverId])
  @@map("payment_refunds")
}

model PendingPayment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId         String?       @unique @map("booking_id") @db.Uuid
  tripId            String?       @map("trip_id") @db.Uuid
  passengerId       String        @map("passenger_id") @db.Uuid
  driverId          String        @map("driver_id") @db.Uuid
  txRef             String        @unique @map("tx_ref") @db.VarChar(255)
  provider          String        @default("paychangu") @db.VarChar(50)
  paymentMethod     PaymentMethod @map("payment_method")
  boardingPoint     String?       @map("boarding_point") @db.VarChar(255)
  dropOffPoint      String?       @map("drop_off_point") @db.VarChar(255)
  fareAmountMwk     BigInt        @map("fare_amount_mwk")
  providerFeeMwk    BigInt        @map("provider_fee_mwk")
  providerFeeRate   Decimal       @map("provider_fee_rate") @db.Decimal(8, 4)
  systemFeeMwk      BigInt        @map("system_fee_mwk")
  systemFeeRate     Decimal       @map("system_fee_rate") @db.Decimal(8, 4)
  customerAmountMwk BigInt        @map("customer_amount_mwk")
  driverAmountMwk   BigInt        @map("driver_amount_mwk")
  currency          String        @default("MWK") @db.VarChar(8)
  status            String        @default("pending") @db.VarChar(30)
  checkoutUrl       String?       @map("checkout_url")
  gatewayReference  String?       @map("gateway_reference") @db.VarChar(255)
  providerPayload   Json?         @map("provider_payload")
  failureReason     String?       @map("failure_reason")
  verifiedAt        DateTime?     @map("verified_at") @db.Timestamptz()
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  booking   Booking?      @relation(fields: [bookingId], references: [id])
  trip      Trip?         @relation(fields: [tripId], references: [id])
  passenger User          @relation(fields: [passengerId], references: [id])
  driver    DriverProfile @relation(fields: [driverId], references: [id])

  @@map("pending_payments")
}

model DriverWallet {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId        String   @unique @map("driver_id") @db.Uuid
  balanceMwk      BigInt   @default(0) @map("balance_mwk")
  totalEarnedMwk  BigInt   @default(0) @map("total_earned_mwk")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  driver DriverProfile @relation(fields: [driverId], references: [id])

  @@map("driver_wallet")
}

model WalletWithdrawalRequest {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId    String                 @map("driver_id") @db.Uuid
  amountMwk   BigInt                 @map("amount_mwk")
  phone       String                 @db.VarChar(30)
  provider    String                 @db.VarChar(50)
  status      WalletWithdrawalStatus @default(queued)
  reference   String                 @unique
  walletTxId  String?                @unique @map("wallet_tx_id") @db.Uuid
  failureReason String?              @map("failure_reason")
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  processedAt DateTime?              @map("processed_at") @db.Timestamptz()

  driver   DriverProfile      @relation(fields: [driverId], references: [id])
  walletTx WalletTransaction? @relation(fields: [walletTxId], references: [id])

  @@index([driverId, status])
  @@map("wallet_withdrawal_requests")
}

model OtpCode {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  purpose   OtpPurpose
  codeHash  String     @map("code_hash") @db.Char(60)
  status    OtpStatus  @default(active)
  expiresAt DateTime   @map("expires_at") @db.Timestamptz()
  usedAt    DateTime?  @map("used_at") @db.Timestamptz()
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, status])
  @@map("otp_codes")
}

model WalletTransaction {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId         String        @map("driver_id") @db.Uuid
  type             WalletTxType
  kind             WalletTxKind? 
  amountMwk        BigInt        @map("amount_mwk")
  balanceBeforeMwk BigInt?       @map("balance_before_mwk")
  balanceAfterMwk  BigInt?       @map("balance_after_mwk")
  bookingId        String?       @map("booking_id") @db.Uuid
  paymentId        String?       @map("payment_id") @db.Uuid
  refundId         String?       @map("refund_id") @db.Uuid
  reference        String?
  metadata         Json?
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  driver  DriverProfile  @relation(fields: [driverId], references: [id])
  booking Booking?       @relation(fields: [bookingId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])
  refund  PaymentRefund? @relation(fields: [refundId], references: [id])
  withdrawalRequest WalletWithdrawalRequest?

  @@index([paymentId])
  @@index([refundId])
  @@unique([paymentId, kind])
  @@unique([refundId, kind])
  @@unique([reference, kind])
  @@map("wallet_transactions")
}

model Review {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId   String   @unique @map("booking_id") @db.Uuid
  passengerId String   @map("passenger_id") @db.Uuid
  driverId    String   @map("driver_id") @db.Uuid
  rating      Int      @db.SmallInt
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  booking   Booking       @relation(fields: [bookingId], references: [id])
  passenger User          @relation(fields: [passengerId], references: [id])
  driver    DriverProfile @relation(fields: [driverId], references: [id])

  @@map("reviews")
}


