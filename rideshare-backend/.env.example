# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
API_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/rideshare_mw

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=
REDIS_HOST=91.108.121.232
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_QUEUE_PREFIX=rideshare
QUEUE_WORKERS_ENABLED=true
PAYMENT_WEBHOOK_QUEUE_CONCURRENCY=5
NOTIFICATION_QUEUE_CONCURRENCY=10
WITHDRAWAL_QUEUE_CONCURRENCY=5
WITHDRAWAL_MOBILE_MONEY_FEE_RATE=0.03
WITHDRAWAL_BANK_FEE_RATE=0.01
WITHDRAWAL_BANK_FIXED_FEE=700
WITHDRAWAL_PROCESSING_TIMEOUT_MINUTES=30

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Africa's Talking (SMS) ───────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=RideShare
SMS_DEFAULT_COUNTRY_CODE=+265

# ─── Firebase Admin (FCM) ─────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Google Maps Platform ─────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# ─── Paychangu (Payment Gateway) ────────────────────────
PAYCHANGU_SECRET_KEY=your_paychangu_secret_key
PAYCHANGU_PUBLIC_KEY=your_paychangu_public_key
PAYCHANGU_BASE_URL=https://api.paychangu.com
PAYCHANGU_WEBHOOK_SECRET=your_paychangu_webhook_secret

# ─── ImageKit ─────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# ─── Platform Config ──────────────────────────────────────
COMMISSION_RATE=0.15
OTP_TTL_SECONDS=300
SECRET_CODE_TTL_HOURS=2
